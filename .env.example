# -----------------------------------------------
# @sayari/server
# -----------------------------------------------

# PostgreSQL connection string
DATABASE_URL=postgres://user:password@localhost:5432/sayari

# Secret used to sign JWTs — use a long random string in production
JWT_SECRET=change-me

# URL of the frontend, used for CORS allow-list
FRONTEND_URL=http://localhost:3000

# Port the NestJS server listens on (default: 8000)
PORT=8000

# Credentials for the seeded admin account
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# -----------------------------------------------
# @sayari/web
# -----------------------------------------------

# Base URL of the NestJS API, exposed to the browser
NEXT_PUBLIC_API_URL=http://localhost:8000
